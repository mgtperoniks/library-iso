<script>
        // Simple micro-interaction for sidebar collapse (visual only)
        document.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.key === 'b') {
                const aside = document.querySelector('aside.fixed');
                const main = document.querySelector('main');
                if (aside.style.width === '64px') {
                    aside.style.width = '260px';
                    main.style.marginLeft = '260px';
                    aside.querySelectorAll('span:not(.material-symbols-outlined)').forEach(s => s.style.display = 'inline');
                    aside.querySelector('h1').style.display = 'block';
                    aside.querySelector('p').style.display = 'block';
                } else {
                    aside.style.width = '64px';
                    main.style.marginLeft = '64px';
                    aside.querySelectorAll('span:not(.material-symbols-outlined)').forEach(s => s.style.display = 'none');
                    aside.querySelector('h1').style.display = 'none';
                    aside.querySelector('p').style.display = 'none';
                }
            }
        });

        // Search bar interaction
        const searchInput = document.querySelector('input[placeholder="Search Document Repository..."]');
        searchInput.addEventListener('focus', () => {
            searchInput.parentElement.classList.add('ring-2', 'ring-primary/20');
        });
        searchInput.addEventListener('blur', () => {
            searchInput.parentElement.classList.remove('ring-2', 'ring-primary/20');
        });
    </script>
