<div class="bg-surface-container border-t border-outline-variant px-lg py-md flex justify-end gap-md">
<button class="px-lg py-sm bg-primary text-on-primary font-label-md text-label-md rounded-lg hover:opacity-90 transition-opacity" onclick="closePreview()">
                    Return to Queue
                </button>
</div>
</div>
</div>
<script>
        let activeDocId = null;

        function handleApproval(docId) {
            if(confirm(`Confirm official approval of document ${docId}? This will trigger an automated audit log entry.`)) {
                alert(`Document ${docId} has been approved and moved to active status.`);
                // In a real app, we would remove the element or refresh
            }
        }

        function toggleRejectModal(docId = null) {
            const modal = document.getElementById('reject-modal');
            const content = document.getElementById('modal-content');
            
            if (docId) {
                activeDocId = docId;
                document.getElementById('reject-doc-id').textContent = docId;
                modal.classList.remove('hidden');
                setTimeout(() => {
                    content.classList.remove('scale-95', 'opacity-0');
                    content.classList.add('scale-100', 'opacity-100');
                }, 10);
            } else {
                content.classList.add('scale-95', 'opacity-0');
                content.classList.remove('scale-100', 'opacity-100');
                setTimeout(() => {
                    modal.classList.add('hidden');
                    document.getElementById('reject-reason').value = '';
                }, 300);
            }
        }

        function submitRejection() {
            const reason = document.getElementById('reject-reason').value.trim();
            if (!reason) {
                alert('Please provide a reason for rejection.');
                return;
            }
            alert(`Document ${activeDocId} rejected. Reason: ${reason}`);
            toggleRejectModal();
        }

        function openPreview() {
            const overlay = document.getElementById('preview-overlay');
            overlay.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closePreview() {
            const overlay = document.getElementById('preview-overlay');
            overlay.classList.add('hidden');
            document.body.style.overflow = '';
        }

        // Search Filter Simulation
        document.querySelector('input[type="text"]').addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase();
            const cards = document.querySelectorAll('.approval-card');
            let visibleCount = 0;

            cards.forEach(card => {
                const text = card.textContent.toLowerCase();
                if (text.includes(query)) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            const emptyState = document.getElementById('empty-state');
            if (visibleCount === 0) {
                emptyState.classList.remove('hidden');
                emptyState.classList.add('flex');
            } else {
                emptyState.classList.add('hidden');
                emptyState.classList.remove('flex');
            }
        });
    </script>
</body></html>