<span class="font-code-sm text-code-sm text-secondary">Peroni Quality Hub v2.4.0 | ISO 9001:2015 Compliant</span>
<div class="flex gap-lg">
<a class="font-code-sm text-code-sm text-on-surface-variant hover:text-primary transition-colors" href="#">System Status</a>
<a class="font-code-sm text-code-sm text-on-surface-variant hover:text-primary transition-colors" href="#">Privacy Policy</a>
<a class="font-code-sm text-code-sm text-on-surface-variant hover:text-primary transition-colors" href="#">Documentation</a>
</div>
</footer>
<script>
        // Micro-interaction: Sidebar toggle simulation (visual only)
        document.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.key === 'b') {
                const aside = document.querySelector('aside');
                const main = document.querySelector('main');
                const header = document.querySelector('header');
                const footer = document.querySelector('footer');
                
                if (aside.classList.contains('w-[260px]')) {
                    aside.classList.remove('w-[260px]');
                    aside.classList.add('w-[64px]');
                    main.classList.replace('ml-[260px]', 'ml-[64px]');
                    header.classList.replace('w-[calc(100%-260px)]', 'w-[calc(100%-64px)]');
                    footer.classList.replace('ml-[260px]', 'ml-[64px]');
                    footer.classList.replace('w-[calc(100%-260px)]', 'w-[calc(100%-64px)]');
                } else {
                    aside.classList.remove('w-[64px]');
                    aside.classList.add('w-[260px]');
                    main.classList.replace('ml-[64px]', 'ml-[260px]');
                    header.classList.replace('w-[calc(100%-64px)]', 'w-[calc(100%-260px)]');
                    footer.classList.replace('ml-[64px]', 'ml-[260px]');
                    footer.classList.replace('w-[calc(100%-64px)]', 'w-[calc(100%-260px)]');
                }
            }
        });
    </script>
</body></html>